# Supabase — copy this file to `.env` and fill in your project's values.
# Find both in the Supabase dashboard: Project Settings → API.
# The EXPO_PUBLIC_ prefix is required for Expo to expose them to the app bundle.
# Restart the dev server after editing (`npx expo start -c`).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Google Sign-In (native). Both are OAuth *client IDs* from Google Cloud Console
# (not secrets). The WEB client id is the one also used in the Supabase Google
# provider; the IOS client id is the one whose download was a .plist.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxxx.apps.googleusercontent.com
