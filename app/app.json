{
  "expo": {
    "name": "mysetup",
    "slug": "mysetup",
    "version": "1.0.0",
    "scheme": "mysetup",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mysetup.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F0F0F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.mysetup.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow mysetup to access your camera to scan your desk setup."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow mysetup to access your photos for setup images, profile pictures, and profile banners."
        }
      ],
      [
        "expo-media-library",
        {
          "savePhotosPermission": "Allow mysetup to save your generated setup photos to your camera roll."
        }
      ],
      "expo-video",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "91cc3bb3-f257-479d-958b-8f7afe8b97ca"
      }
    }
  }
}
